<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                                      https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <entity name="App\Component\Order\Entity\OrderPromotion" table="bookshop_order_promotion">

        <id name="id" type="integer">
            <generator strategy="AUTO"/>
        </id>

        <many-to-one field="order"
                     target-entity="App\Component\Order\Entity\Order"
                     inversed-by="orderPromotions">
            <join-column name="order_id"
                         referenced-column-name="id"
                         nullable="false"
                         on-delete="CASCADE"/>
        </many-to-one>

        <many-to-one field="promotion"
                     target-entity="App\Component\Promotion\Entity\Promotion">
            <join-column name="promotion_id"
                         referenced-column-name="id"
                         nullable="false"
                         on-delete="CASCADE"/>
        </many-to-one>

        <field name="createdAt" type="datetime_immutable" nullable="true"/>
        <field name="updatedAt" type="datetime_immutable" nullable="true"/>

    </entity>

</doctrine-mapping>